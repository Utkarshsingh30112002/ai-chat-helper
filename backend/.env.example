PORT=8000
APP_SECRET=change-me

# If GEMINI_API_KEY is set, Gemini is used for /v1/suggest (Google AI Studio / API key).
# Otherwise OPENAI_API_KEY is required.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# Per client IP (default 30 per minute). /health is not rate-limited.
RATE_LIMIT_MAX=30
RATE_LIMIT_TIME_WINDOW=1 minute

# JSON-lines agent log (default ./logs/suggestions.log). Events: suggest_success, suggest_failure
# SUGGEST_LOG_FILE=/var/log/reply-assistant/suggestions.log
# SUGGEST_LOG_INCLUDE_MESSAGE=false
# SUGGEST_LOG_MESSAGE_MAX_CHARS=2000

# Android client diagnostics (default ./logs/client.log)
# CLIENT_LOG_FILE=./logs/client.log
